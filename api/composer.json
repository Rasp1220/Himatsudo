{
    "name": "himatsudo/api",
    "description": "Himatsudo Article CMS - REST API (BearSunday)",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.1",
        "bear/sunday": "^1.6",
        "bear/package": "^1.8",
        "ray/aura-sql-module": "^1.11",
        "aura/sql": "^5.0",
        "lcobucci/jwt": "^5.0",
        "lcobucci/clock": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Himatsudo\\Api\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "post-autoload-dump": [
            "BEAR\\Package\\Compiler::compile"
        ]
    }
}
