{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",

  "extends": [
    "config:recommended"
  ],

  "timezone": "Asia/Tokyo",

  "labels": [
    "dependencies"
  ],

  "packageRules": [
    {
      "matchManagers": ["npm"],
      "groupName": "npm dependencies"
    },
    {
      "matchManagers": ["composer"],
      "groupName": "composer dependencies"
    }
  ]
}