{
    "name": "himatsudo/frontend",
    "description": "Himatsudo Article CMS - Frontend (BearSunday + Qiq)",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.1",
        "bear/sunday": "^1.6",
        "bear/package": "^1.8",
        "qiq/qiq": "^3.0",
        "ray/aura-sql-module": "^1.11",
        "aura/sql": "^5.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "Himatsudo\\Frontend\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "post-autoload-dump": [
            "BEAR\\Package\\Compiler::compile"
        ]
    }
}
