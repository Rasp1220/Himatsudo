{
  "name": "himatsudo-cms",
  "version": "1.0.0",
  "description": "Himatsudo Article CMS - Admin Panel",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
